            }
        }else{
            imglim=specify_width;
        }

        $("#memo_content_"+mode).find("div, span, dl, dd, p").each(function(){
            if($(this).attr("nopop")!=1&&$(this).attr("imgprotect")!=1){ $(this).css({ width: '' }); $(this).removeAttr('width'); }
