var CmtSearchUtil = {
	form : null,
	inited : false,
	init : function() {
		this.form = document.getElementById("searchForm");
		this.inited = true;
	},

	searchComment : function() {
		if(!this.inited){ this.init(); }
		this.form.query.value = document.getElementById("q").value;
		this.form.submit();
	},

	searchOption : function(value) {
		if(!this.inited){ this.init(); }
		this.form.searchOption.value = value;
		if(this.form.pagenum){
			this.form.pagenum.value = "1";
		}
		this.form.submit();
	},

	mediaInfo : function(value) {
		if(!this.inited){ this.init(); }
		this.form.media_info.value = value;
		this.form.submit();
	}
}


var CommentManager = {
	isSelectedTotal: false,
	toggleCheck: function(checkName){
		if (this.isSelectedTotal == true){
			this.unCheckedAllComment(checkName);
			this.isSelectedTotal = false;
		} else {
			this.checkedAllComment(checkName);
			this.isSelectedTotal = true;
		}
	},
	checkedAllComment: function(checkName){
		jQuery("input:checkbox[name=" + checkName + "]").prop("checked", true);
	},
	unCheckedAllComment: function(checkName){
		jQuery("input:checkbox[name=" + checkName + "]").prop("checked", false);
	},
	deleteComment: function(checkName){
		this.deleteCheckedComment(checkName, false);
	},
	deleteSpamComment: function(checkName){
		this.deleteCheckedComment(checkName, true);
	},
	deleteCheckedComment: function(checkName, isSpam){
		var checkedList = jQuery("input:checkbox[name=" + checkName + "]:checked");

		if (isSpam){
			if (!this.hasSelection(checkedList, '스팸처리할 게시물을 선택해 주세요.')) { return; }
			if (!confirm("스팸처리를 하시겠습니까?\n해당 댓글 삭제와 동시에 회원은 활동중지 됩니다.")) { return; }
		}else{
			if (!this.hasSelection(checkedList, '삭제할 게시물을 선택해 주세요.')) { return; }
			if (!confirm("정말로 삭제하시겠습니까?")) { return; }
		}

		var comments = [];
		checkedList.each(function(i, cmt){
			var cmtData = cmt.value.split("::");
			var comment = {
				fldid: cmtData[0],
				dataid: cmtData[1],
				seq: cmtData[2]
			};
			comments.push(comment);
		});
		ShortComment.removeListForSearch(
			comments,
			isSpam,
			function(){
				window.location.reload();
		});
	},
	hasSelection: function(checkedList, msg){
		if (checkedList && checkedList.length > 0){
			return true;
		}else{
			if (msg != 'undefined' && msg != '') {
				alert(msg);
			}
			return false;
		}
	}
}

function changeSearchType(select, targetId, form) {
	form.item.value = select.value;
	checkFldheadList(select, targetId);
}

function checkFldheadList(select, targetId){
	if (select.value == "head"){
		jQuery('#' + targetId).show();
	} else {
		jQuery('#' + targetId).hide();
	}
}


function dispmesg(actionType, targetFldid, el) {
    if(!document.innerSearchForm.dataid) {
        return;
    }

    var flag=0;
    var count=0;

    for(i=0;i<document.innerSearchForm.dataid.length;i++){
        if(document.innerSearchForm.dataid[i].checked){
            count++;
        }
    }
    if (count > 50) {
		alert('게시글 이동/삭제/신고는\n한 번에 최대 50개까지만 가능합니다.');
		return;
	}
    //공지글 체크 와 스팸 게시물 체크
    if(document.innerSearchForm.dataid.length > 0){
        for(var i=0;i<document.innerSearchForm.dataid.length;i++){
            if(document.innerSearchForm.dataid[i].checked){
                if(actionType == "mv" && ":"+CAFEAPP.ui.NOTIDATAIDS+":".indexOf( ":" + document.innerSearchForm.dataid[i].value + ":" ) > -1  ) {
                    if (count == 1) {
                        alert("공지로 지정된 게시물은 이동할 수 없습니다.");
                    } else {
                        alert("공지로 지정된 게시물은 이동할 수 없습니다. \n공지글 지정을 해제하신 후 이동해 주세요.");
                    }
                    return;
                }
                flag=1;
            }
        }
    } else{
        if(document.innerSearchForm.dataid.checked) {
            if(actionType == "mv" &&
                document.innerSearchForm.dataid.value == CAFEAPP.ui.NOTIDATAID) {
                alert("공지로 지정된 게시물은 이동할 수 없습니다.");
                return;
            }
            flag=1;
        }
    }

    if(!flag) {
    	if (actionType == "mv") {
            alert("이동할 게시물을 선택해 주세요");
        }
        return;
    }

    if(actionType == "mv"){

        if (targetFldid == CAFEAPP.FLDID) {
            alert("동일한 게시판으로의 이동은 불가능합니다.\n다른 게시판을 선택해 주세요.");
            return;
        }

        if(confirm("정말로 이동하시겠습니까?")){
            document.innerSearchForm.moveto.value = targetFldid;
            document.innerSearchForm.action="/_c21_/bbs_move_action?grpid="+CAFEAPP.GRPID+"&fldid="+CAFEAPP.FLDID;

        }else {
            return;
        }
    }else {
        return;
    }
	el.onclick = function(e) {e.preventDefault(); return false;}
	document.innerSearchForm.submit();
}
