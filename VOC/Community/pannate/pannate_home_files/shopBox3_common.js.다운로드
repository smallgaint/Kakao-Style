function fillData(targetData, sourceData, maxCount, startIndex = 0) {
  const needCount = maxCount - targetData.length;

  if (needCount <= 0) {
    return {
      data: targetData,
      nextIndex: startIndex
    };
  }

  const addData = sourceData.slice(startIndex, startIndex + needCount);

  return {
    data: targetData.concat(addData),
    nextIndex: startIndex + addData.length
  };
}

