function bindItemList(list, startPageNum, cnt, itemTextBuilder, options = {}) {
  const bindItem = options.bindItem || defaultBindItem;
  const pushPageData = options.pushPageData || false;

  list.forEach((obj, i) => {
    const pageNum = startPageNum + Math.floor(i / cnt);
    const itemNum = i % cnt;

    if (pushPageData) {
      cpcPageData['page' + pageNum].push(obj);
    }

    const textInfo = itemTextBuilder(obj);
    bindItem(pageNum, itemNum, obj, textInfo.title, textInfo.desc);
  });
}

