
function shuffleArray(array) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

function sortArray(array, priorities) {
  return array.sort((a, b) => {
    for (let text of priorities) {
      const aHas = a.purl && a.purl.includes(text);
      const bHas = b.purl && b.purl.includes(text);
      if (aHas && !bHas) return -1; // a 우선
      if (!aHas && bHas) return 1;  // b 우선
    }
    return 0; // 동일 조건이면 그대로
  });
}
function getPrice(value) {
  if (typeof value === 'string' && /^[0-9]+$/.test(value)) {
    return Number(value).toLocaleString() + "원";
  }
  return value;
}
function splitShuffleMerge(payload) {
  const items = payload;

  const conv = []
  const convTarget = []
  const convNonTarget = []
  const nonConv = []

  for (const item of items) {
    const url = item?.purl ?? ""
    if (url.includes("isTune=true")) conv.push(item);
    else nonConv.push(item);
  }

  for (const item of conv) {
    const url = item?.purl ?? ""
    if (url.includes("CRVCART") || url.includes("CRVVIEW")) convTarget.push(item);
    else convNonTarget.push(item);
  }

  const mixed = shuffleArray(convTarget).concat(shuffleArray(convNonTarget)).concat(shuffleArray(nonConv));

  // 필요하면 원본 payload 형태 유지해서 반환
  return mixed;
}

