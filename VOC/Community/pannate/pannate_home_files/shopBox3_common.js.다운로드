// impUrl 합쳐서 imps 로 전송(캠페인, 소재 노출수)
async function sendImps(pathname, datas){
  try{
    if(datas === null || datas === undefined || datas.length === 0){
      return;
    }

    let impsUrl = '';
    const payload = [];
    datas.forEach((item, idx)=>{
      let url = new URL(item);
      let param = Object.fromEntries(url.searchParams.entries());
      if(idx == 0){
        impsUrl = url.origin;
        if(pathname === null || pathname === undefined || pathname === ''){
          impsUrl += url.pathname;
        }
        else{
          impsUrl += pathname;
        }
      }
      payload.push({
        adParamRequest : {
          zone: param.zone
          , output: param.output
          , count: param.count
          , w: param.w
          , h: param.h
          , adid: param.adid
          , auid: param.auid
          , uni1Id: param.uni1Id
          , uniqueId: param.uniqueId
          , pb: param.pb
          , pbUrl: param.pbUrl
          , advrtsPrdtCode: param.advrtsPrdtCode
          , ad: param.ad
        },
        mobTuneTrackingParam : {
          mo_source : param.mo_source
          , mo_medium : param.mo_medium
          , mo_campaign : param.mo_campaign
          , mo_content : param.mo_content
          , isTune : param.isTune
        }
      });
    });

    if(impsUrl !== '' && impsUrl !== null && impsUrl !== undefined){
      fetch(impsUrl, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).catch(error => {});
    }
  } catch(e) {}

}

/**
 * 한번만 실행되게 하는 함수, 노출,소재통계 api실행할때 사용
 * @param selector
 * @param callback
 */
function monitorShowOnce(selector, callback) {
  try{
    const $el = $(selector);
    let executed = false;

    // DOM 변화 감지용 MutationObserver
    const observer = new MutationObserver(() => {
      if ($el.is(":visible") && !executed) {
        executed = true;
        callback();
        observer.disconnect(); // 더 이상 감시하지 않음
      }
    });

    observer.observe($el[0], { attributes: true, childList: true, subtree: true });

    // 초기 상태 체크 (이미 보이는 경우)
    if ($el.is(":visible") && !executed) {
      executed = true;
      callback();
      observer.disconnect();
    }
  }catch(e){}
}