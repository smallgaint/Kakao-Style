            (function() {
                // top 버튼 클릭 시 공통 동작 함수
                function scrollToTop(e) {
                    e.preventDefault();
                    var stickyEl = document.querySelector('.sticky-wrap');
                    if (stickyEl) {
                        stickyEl.removeAttribute("style");
                        console.log("sticky 스타일 제거됨");
                    }
                    if (window.location.hash) {
                        history.replaceState(null, null, window.location.pathname + window.location.search);
                    }
                    window.scrollTo({
                        top: 0
                    });
                }

                // top 버튼 및 네비 상단 버튼 이벤트 등록
                var pageTop = document.querySelector('.go_top a');
                var pageNaviBtnTop = document.querySelector('#page_navi_btn_top');
                if (pageTop) {
                    pageTop.addEventListener('click', scrollToTop);
                }
                if (pageNaviBtnTop) {
                    pageNaviBtnTop.addEventListener('click', scrollToTop);
                }

                // sticky 기능
                function makeSticky(stickyEl, container) {
                    var prevScroll = window.pageYOffset || document.documentElement.scrollTop;
                    var sticky = false;
                    var headerH = container.offsetTop;

                    window.addEventListener('scroll', function() {
                        stickyController();
                    });

                    function stickyBottomVisible(el) {
                        var elementBottom = el.offsetTop + el.offsetHeight;
                        var viewportBottom = window.pageYOffset + window.innerHeight - headerH;
                        return elementBottom <= viewportBottom;
                    }

                    function stickyController() {
                        var stickyBottom = stickyBottomVisible(stickyEl);
                        var currentScroll = window.pageYOffset || document.documentElement.scrollTop;

                        // 스크롤이 최상단이면 바로 리턴
                        if (currentScroll === 0) {
                            stickyEl.removeAttribute("style");
                            sticky = false;
                            prevScroll = currentScroll;
                            return;
                        }

                        // 스크롤 다운
                        if (currentScroll > prevScroll) {
                            if (!sticky && stickyBottom) {
                                stickyEl.style.position = 'fixed';
                                stickyEl.style.bottom = '0px';
                                sticky = true;
                            }
                            // 컨테이너 영역을 벗어나면 고정 해제
                            if (sticky && container.offsetTop + container.offsetHeight <= currentScroll + window.innerHeight) {
                                stickyEl.style.position = 'absolute';
                                stickyEl.style.bottom = '0px';
                                sticky = false;
                            }
                        }
                        // 스크롤 업
                        else {
                            if (!sticky && container.offsetTop <= currentScroll && container.offsetTop + container.offsetHeight > currentScroll + window.innerHeight) {
                                stickyEl.style.position = 'fixed';
                                stickyEl.style.bottom = '0px';
                                sticky = true;
                            }
                            if (sticky && (stickyEl.offsetTop + prevScroll) <= container.offsetTop) {
                                stickyEl.removeAttribute("style");
                                sticky = false;
                            }
                        }

                        prevScroll = currentScroll;
                    }
                }

                // sticky 초기화 (viewarea 높이와 sticky-wrap 높이 비교)
                var _init = false;
                setTimeout(function() {
                    var viewarea = document.querySelector('.viewarea');
                    var stickyWrap = document.querySelector('.sticky-wrap');
                    if (viewarea && stickyWrap) {
                        var isLonger = viewarea.clientHeight > stickyWrap.clientHeight;
                        if (isLonger) {
                            var container = document.getElementById('sideArea');
                            if (container) {
                                makeSticky(stickyWrap, container);
                                _init = true;
                            }
                        }
                    }
                }, 0);

                window.addEventListener('hashchange', function() {
                    var stickyWrap = document.querySelector('.sticky-wrap');
                    if (stickyWrap) {
                        // 해시 변경 후 초기화 필요시 _init을 false로 재설정
                        stickyWrap.removeAttribute("style");
                        _init = false;
                    }
                });

                // 스크롤 시 sticky 초기화 재확인 (최초 초기화 안된 경우)
                window.addEventListener('scroll', function() {
                    var viewarea = document.querySelector('.viewarea');
                    var stickyWrap = document.querySelector('.sticky-wrap');
                    if (viewarea && stickyWrap) {
                        var isLonger = viewarea.clientHeight > stickyWrap.clientHeight;
                        if (isLonger && !_init) {
                            var container = document.getElementById('sideArea');
                            if (container) {
                                makeSticky(stickyWrap, container);
                                _init = true;
                            }
                        }
                    }
                });
            })()

