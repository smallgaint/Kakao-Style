            "</head>\n" +
            "<body>\n" +
            "    <a href=\"https://www.mobwithad.com/click?advrtsPrdtCode=01&zone=0&ad=2468\" target=\"_blank\" style=\"width:"
            + width + "px;\">\n" +
            "\t\t\t<img src=\"https://img.mobwithad.com/ad/imgfile/default/shopBox/"
            + width + "x" + height + ".png\" width=\"100%\" height=\"" + height
            + "px\" />\n" +
            "    </a>\n" +
            "    <img src=\"https://www.mobwithad.com/imp?advrtsPrdtCode=01&zone=0&ad=2468\" width=\"0\" height=\"0\" />\n"
            +
            "</body>\n" +
            "</html>\n" +
            "<!-- SORTLIST : {{SORTLIST}} -->";

        callback(defulatPage);
      }
    }
  };
  xhr.open(method, uri, true);
  xhr.send();
}

var renderIframe = function (zone, auid, adid, h, w, adType, bannerType, pb, position, no) {
  var domain = 'https://nate.mobwithad.com/';
  if(auid === ''){
    auid = extractAuid(auid);
  }
  var uri;
  switch (adType){
    case "cover": uri = '//www.mobwithad.com/' + adType + '?zone=' + zone + '&w=' + w + '&h='+ h + '&pb=' + pb; break;
    case "banner": uri = domain + 'api/banner/shopBox/nate/v1/banner?zone=' + zone + '&auid=' + auid + '&adid=' + adid + '&output=script&w=' + w + '&h=' + h; break;
    case "shopBox": uri = domain + 'api/banner/shopBox/nate/v1/shopBox?zone=' + zone + '&auid=' + auid + '&adid=' + adid + '&output=json_script&w=' + w + '&h=' + h; break;
    default: break;
  }

  xhrRequest('GET', uri, function (result) {
    var ifr = document.getElementById('wrap_' + no);
    ifr.contentDocument.write(result);
    ifr.contentDocument.close();
  });
}
var gridFrame = function (no, param) {
  const frame = document.querySelector("#wrap_" + no);
  const container = document.querySelector("#div_" + no);
  const ratio = 840 / 640;

  if (!container) return;

  var containerWidth;
  var currentScript = document.currentScript;
  containerWidth = currentScript.parentNode.clientWidth;

  const width = containerWidth;
  const height = (width + 160) * ratio ;
  frame.width = width + "px";
  frame.height = height + "px";

  container.style.width = "100%";
}
var resizeFrame = function (no, param) {
  const frame = document.querySelector("#wrap_" + no);
  const container = document.querySelector("#div_" + no);
  const ratio = 840 / 640;

  if (!container) return;

  var containerWidth = window.innerWidth;

  const width = containerWidth;
  const height = (width + 160) * ratio ;

  var adDiv = document.querySelector("#ifr_main_banner");

  if(adDiv == null) {
    if(width <= 640){
      frame.width = width + "px";
      frame.height = height + "px";
    } else {
      frame.width = "100%";
      frame.height = (width/2 + 160) * ratio ;
    }
  } else {
    frame.width = width + "px";
    frame.height = height + "px";
  }
  container.style.width = "100%";
}
var writeFrame = function (param) {

  const script = document.currentScript;
  const container = script.parentNode;
  const uniqueId = param.zone + "_" + Date.now();

  var a = document.createElement("iframe");
  a.id = "wrap_" + uniqueId;
  a.referrerPolicy = 'no-referrer';
  a.frameBorder = 0;
  a.scrolling = 'no';
  a.style = 'z-index:99;overflow-x:hidden; overflow:auto; max-Height:1155px';
  a.width = param.width;
  a.height = param.height;

  var f = layout(param, uniqueId);
  f.appendChild(a);
  container.appendChild(f);

  observeVisible(f, param);
  return uniqueId;
}

function observeVisible(target, param) {
  let called = false;

  const observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting && !called) {
        called = true;

        callImpressionApi(param);

        observer.unobserve(target);
        observer.disconnect();
      }
    });
  }, {
    root: null,
    rootMargin: '0px',
    threshold: 0.15
  });

  observer.observe(target);
}

function callImpressionApi(param) {
  fetch('https://nate.mobwithad.com/etc/incrementCount/shopBox', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      zone: param.zone
    })
  })
  .then(function (res) {})
  .catch(function (err) {
    console.error('API error', err);
  });
}

function extractAuid(auid) {
  var mobonAuid = auid;
  if(auid === '' && typeof window.getMobLoaclStorage === 'function'){
    mobonAuid = getMobLoaclStorage();
  }
  return mobonAuid;
}

