function MobWithShopBox(param) {
  var no = writeFrame(param);
  var script = document.createElement('script');
  script.src = 'https://img.mobon.net/js/common/HawkUtil.js';
  script.onload = function () {
    renderIframe(param.zone, param.auid, param.adid, param.height, param.width, param.adType, param.bannerType, param.pb, param.position, no);
  }
  script.onerror = function() {
    renderIframe(param.zone, param.auid, param.adid, param.height, param.width, param.adType, param.bannerType, param.pb, param.position, no);
  }
  document.head.append(script);
  if(param.width === "360"){
    resizeFrame(no, param);
    window.addEventListener("resize", () => resizeFrame(no, param));
  }
}

var layout = function (param, no) {
  return bottom(param, no);
}

// 화면 위치
var bottom = function (param, no) {
  var f = document.createElement("div");
  f.id = "div_" + no;
  f.style = 'width:' + param.width + 'px; margin: auto;';
  return f;
}
var xhrRequest = function (method, uri, callback) {
  var xhr = new XMLHttpRequest();
  xhr.onreadystatechange = function () {
    if (xhr.readyState === 4) {
      if (xhr.status === 200 && xhr.responseText.indexOf('noad') == -1) {
        callback(xhr.responseText);
      } else {
        var result = {};
        uri.replace(/[?&]{1}([^=&#]+)=([^&#]*)/g, function (s, k, v) {
          result[k] = decodeURIComponent(v);
        });
        var width = result.w
        var height = result.h

        var defulatPage =
            "<!DOCTYPE html>\n" +
            "<html lang=\"en\">\n" +
            "<head>\n" +
            "    <meta http-equiv=\"content-type\" content=\"text/html;charset=utf-8\">    \n"
            +
            "    <meta http-equiv=\"Cache-Control\" content=\"no-cache, no-store, must-revalidate\">\n"
            +
            "\t\t<meta http-equiv=\"Pragma\" content=\"no-cache\">\n" +
            "\t\t<meta http-equiv=\"Expires\" content=\"0\">\n" +
            "    <style type=\"text/css\">\n" +
            "        body { margin: 0; padding: 0; overflow: hidden; }\n" +
            "        a, div, img { margin: 0; padding: 0; border: 0; display: block; }\n"
            +
            "    </style>\n" +
