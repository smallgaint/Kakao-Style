var Util = {
	Validator:{
		isDateYYYYMMDD:function(txtDate){
			if (txtDate.length !== 8 || isNaN(txtDate)) {
				return false;
			}
			var year = txtDate.substring(0, 4); 
			var month = txtDate.substring(4, 6);
			var day = txtDate.substring(6, 8);
			return Util.Validator.isDate(year, month, day);
		},
		isDateYYYYMMDDHH:function(txtDate){
			if (txtDate.length !== 10 || isNaN(txtDate)) {
				return false;
			}
			var hour = txtDate.substring(8, 10);
			if(hour>24||hour<0){
				return false;
			}
			var yyyymmdd = txtDate.substring(0, 8); 
			return Util.Validator.isDateYYYYMMDD(yyyymmdd);
		},
		isDate:function(strYear,strMonth,strDay){
			// 윤년을 고려한 올바른 연도,월,일자를 입력했는지 검사한다.
			var month = strMonth - 1; // 0~11
			var day = strDay - 0;	 
			var year = strYear - 0; 
			if (year < 1000 || year > 3000) {
				return false;
			}
			var mSeconds = (new Date(year, month, day)).getTime();
			var objDate = new Date();
			objDate.setTime(mSeconds); 

			if (objDate.getFullYear() !== year ||
					objDate.getMonth() !== month ||
					objDate.getDate() !== day) {
				return false;
			}
			return true; 
		}
	}
}

//입력된 char 가 한글인지 판별(유니코드 기반)
function isKor( charCode )
{
	if( (charCode >= 4352 && charCode <= 4607) || (charCode >= 12592 && charCode <= 12687) || (charCode >= 43360 && charCode <= 57251) || (charCode >= 44032 && charCode <= 55203) || (charCode >= 55216 && charCode <= 55295) )
		return true;
	else
		return false;
}

//입력된 char 가 영문인지 판별(유니코드 기반)
function isEng( charCode )
{
	if( (charCode >= 65 && charCode <= 90) || (charCode >= 97 && charCode <= 122) )
		return true;
	else
		return false;
}

//입력된 char 가 숫자인지 판별(유니코드 기반)
function isNum( charCode )
{
	if( charCode >= 48 && charCode <= 57 )
		return true;
	else
		return false;
}

Number.prototype.number_format = function(round_decimal) {
	return this.toFixed(round_decimal).replace(/(\d)(?=(\d{3})+$)/g, "$1,");
}
