function copyToClipboard(val)
{
	try {
		var el = document.createElement('input');
		el.value = val;
		el.style = 'position:absolute;top:-9999em;';
		document.body.appendChild(el);
		el.select();
		document.execCommand("copy");
		el.setSelectionRange(0,0);
		return true;
	}
	catch(e) {
		alert("지원하지 않는 브라우저입니다.");
		return false;
	}

	return false;
} 


