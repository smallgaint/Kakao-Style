 * S : 글자수(byte 기반) 체크 메서드 (IE에서 버그 있음 : checkMaxByte -> isOverflow로 대체)
 ****************************************************************************************************/
var time = null;
function checkMaxByte(obj, maxByte)
{
	var content = obj.value;
	var length = getByteLength(content);

	if ( length > maxByte )
	{
		content = subStrByByte(content, maxByte);
		
		obj.value = '';
		alert(maxByte + 'byte까지 작성가능합니다.');
		obj.value = content;
		obj.focus();
		
		return false;
	}
	
	return true;
}
/* deprecated */
function isOverflow(obj, maxByte){
	var content = obj.val();
	if(getByteLength(content) > maxByte){
		content = subStrByByte(content, maxByte);
		obj.clear();
		alert(maxByte + 'byte까지 작성가능합니다.');
		obj.setValue(content);
		obj.focus();
		return true;
	}
	return false;
}
/* deprecated */

function startCheckMaxByte(obj, maxByte)
{
	checkMaxByte(obj, maxByte);
	
	clearTimeout(time);
	time = window.setTimeout(function() { startCheckMaxByte(obj, maxByte); }, 200);
}

function stopCheckMaxByte(obj, maxByte)
{
	clearTimeout(time);
	time = null;
	
	checkMaxByte(obj, maxByte);
}

function subStrByByte( str, maxByte )
{
	var cutPos = maxByte;
	for (var i = 0; (i < str.length) && (i < maxByte); i++)
	{
		if(str.charCodeAt(i) > 127)
		{
			cutPos--;
			maxByte--;
		}
	}
	return str.substr(0, cutPos);
}

function getByteLength( strData )
{
	var nLen = 0;
	var nLoop;
	for (var nLoop = 0; nLoop < strData.length; nLoop++)
	{
		if(strData.charCodeAt(nLoop) > 127)
			nLen += 2;
		else
			nLen++;
	}

	return nLen;
}
